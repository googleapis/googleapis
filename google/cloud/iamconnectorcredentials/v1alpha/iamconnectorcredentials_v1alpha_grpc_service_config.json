{
  "methodConfig": [{
    "name": [
      { "service": "google.cloud.iamconnectorcredentials.v1alpha.IAMConnectorCredentialsService", "method": "RetrieveCredentials" },
      { "service": "google.cloud.iamconnectorcredentials.v1alpha.IAMConnectorCredentialsService", "method": "FinalizeCredentials" }
    ],
    "timeout": "60s",
    "retryPolicy": {
      "maxAttempts": 5,
      "initialBackoff": "1s",
      "maxBackoff": "10s",
      "backoffMultiplier": 1.3,
      "retryableStatusCodes": ["UNAVAILABLE"]
    }
  }]
}
