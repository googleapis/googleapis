{
  "methodConfig": [{
    "name": [{
      "service": "google.cloud.agentidentitycredentials.v1.AuthProviderCredentialsService"
    }],
    "timeout": "60s",
    "retryPolicy": {
      "maxAttempts": 5,
      "initialBackoff": "1s",
      "maxBackoff": "10s",
      "backoffMultiplier": 1.3,
      "retryableStatusCodes": ["UNAVAILABLE"]
    }
  }]
}
